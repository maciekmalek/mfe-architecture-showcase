{
  "name": "mfe-architecture-showcase",
  "version": "1.0.0",
  "description": "Production-ready micro-frontend architecture with Module Federation, event orchestration, and E2E testing",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "nx run-many --targets=dev --all",
    "build": "nx run-many --targets=build --all",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:all": "pnpm test && pnpm test:e2e",
    "lint": "nx run-many --targets=lint --all"
  },
  "devDependencies": {
    "@nx/next": "^19.0.0",
    "@nx/react": "^19.0.0",
    "@nx/workspace": "^19.0.0",
    "@playwright/test": "^1.40.0",
    "@testing-library/jest-dom": "^6.1.0",
    "@testing-library/react": "^14.0.0",
    "@types/jest": "^29.5.0",
    "@types/node": "^20.0.0",
    "@types/react": "^18.0.0",
    "@typescript-eslint/eslint-plugin": "^6.0.0",
    "@typescript-eslint/parser": "^6.0.0",
    "eslint": "^8.0.0",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "nx": "^19.0.0",
    "typescript": "^5.0.0"
  },
  "dependencies": {
    "next": "^14.0.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0"
  }
}
